# Copy this file to `.env` and fill in the values.

# Where the opencode server is running. By default `opencode serve` listens
# on 127.0.0.1:4096. The opencode desktop app picks a random port and shows
# it in its server settings — use that value here if you're talking to the
# desktop app's embedded server.
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Optional basic auth, only needed if you started the opencode server with
# OPENCODE_SERVER_PASSWORD set. Most local setups leave these blank.
OPENCODE_SERVER_USERNAME=
OPENCODE_SERVER_PASSWORD=

# Port the chat backend will listen on.
SERVER_PORT=3001

# Origin allowed by CORS. Defaults to the Vite dev server.
WEB_ORIGIN=http://localhost:5173
